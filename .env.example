# ==============================
# DaisyClaw — Environment Config
# Copy file này thành .env rồi điền giá trị
# ==============================

# === BẮT BUỘC (Phase 1) ===
OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL=gpt-4o-mini

# === TÙY CHỌN (Phase 1) ===
# SHORT_TERM_MAX=10

# === Phase 2 — Khoẻ: API Server ===
# PORT=3000
# SECRET_TOKEN=your-secret-token-here

# === Phase 2 — Khoẻ: Telegram Bot ===
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF-your-bot-token

# === Phase 3 — Khoẻ: Discord Bot ===
# DISCORD_BOT_TOKEN=your-discord-bot-token